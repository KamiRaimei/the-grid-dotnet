<!-- MainWindow.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:GridSimulation"
        x:Class="GridSimulation.MainWindow"
        Title="GRID SIMULATION - Fibonacci Sequence MCP AI"
        Width="1400"
        Height="900"
        Background="#1E1E28"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">
        <!-- Title Bar -->
        <Border Grid.Row="0" 
                Background="#2D2D3A" 
                CornerRadius="8"
                Margin="0,0,0,10"
                Padding="10">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="GRID SIMULATION - Fibonacci Sequence" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Foreground="#FFD700"/>
                <TextBlock x:Name="StatusText" 
                          Text="Initializing..." 
                          FontSize="14"
                          Foreground="#00FF00"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 400" RowDefinitions="*, 300">
            
            <!-- Left Panel - Grid View -->
            <Border Grid.Column="0"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Background="#2D2D3A"
                    CornerRadius="8"
                    Margin="0,0,10,10"
                    Padding="10">
                <DockPanel>
                    <TextBlock Text="GRID STATUS" 
                              DockPanel.Dock="Top"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#87CEEB"
                              Margin="0,0,0,10"/>
                    
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GridItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:GridCellViewModel">
                                    <Border Width="16" Height="16" Margin="0,0,1,1"
                                            Background="{Binding Background}"
                                            CornerRadius="2">
                                        <TextBlock Text="{Binding Char}" FontSize="12"
                                                FontFamily="Monospace"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right Top Panel - Statistics -->
            <Border Grid.Column="1"
                    Grid.Row="0"
                    Background="#2D2D3A"
                    CornerRadius="8"
                    Margin="0,0,0,10"
                    Padding="10">
                <DockPanel>
                    <TextBlock Text="SYSTEM STATISTICS" 
                              DockPanel.Dock="Top"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#FFA07A"
                              Margin="0,0,0,10"/>
                    
                    <ScrollViewer>
                        <StackPanel Spacing="8">
                            <!-- Stats will be bound here -->
                            <TextBlock x:Name="UserProgramsText" Text="User Programs: 0"/>
                            <TextBlock x:Name="MCPProgramsText" Text="MCP Programs: 0"/>
                            <TextBlock x:Name="GridBugsText" Text="Grid Bugs: 0"/>
                            <TextBlock x:Name="SpecialProgramsText" Text="Special Programs: 0"/>
                            <TextBlock x:Name="EnergyLevelText" Text="Energy Level: 0.00"/>
                            <TextBlock x:Name="StabilityText" Text="Stability: 0.00"/>
                            <TextBlock x:Name="LoopEfficiencyText" Text="Loop Efficiency: 0.00"/>
                            <TextBlock x:Name="CellCooperationText" Text="Cell Cooperation: 0.00"/>
                            <TextBlock x:Name="CalculationRateText" Text="Calculation Rate: 0.00/s"/>
                            <TextBlock x:Name="MCPStateText" Text="MCP State: LEARNING"/>
                            
                            <!-- Progress Bars -->
                            <TextBlock Text="Loop Efficiency" Margin="0,10,0,0"/>
                            <ProgressBar x:Name="LoopEfficiencyBar" Minimum="0" Maximum="1" Height="20"/>
                            
                            <TextBlock Text="Calculation Rate" Margin="0,10,0,0"/>
                            <ProgressBar x:Name="CalculationRateBar" Minimum="0" Maximum="500" Height="20"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right Bottom Panel - MCP Log -->
            <Border Grid.Column="1"
                    Grid.Row="1"
                    Background="#2D2D3A"
                    CornerRadius="8"
                    Margin="0,0,0,0"
                    Padding="10">
                <DockPanel>
                    <TextBlock Text="MCP COMMUNICATION LOG" 
                              DockPanel.Dock="Top"
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="#98FB98"
                              Margin="0,0,0,10"/>
                    
                    <ListBox x:Name="LogListBox" Background="#1E1E28" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" FontSize="11" FontFamily="Monospace" Foreground="#D3D3D3" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom Panel - Command Input -->
        <Border Grid.Row="2"
                Background="#2D2D3A"
                CornerRadius="8"
                Margin="0,10,0,0"
                Padding="10">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                <!-- Command Input -->
                <TextBlock Text="COMMAND:" 
                          Grid.Column="0"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"
                          Foreground="#D3D3D3"/>
                
                <TextBox x:Name="CommandTextBox"
                        Grid.Column="1"
                        Watermark="Enter command..."
                        Background="#1E1E28"
                        Foreground="White"
                        Height="30"
                        Margin="0,0,10,0"/>
                
                <Button x:Name="SendButton"
                       Grid.Column="2"
                       Content="SEND"
                       Width="80"
                       Height="30"
                       Background="#0078D7"
                       Margin="0,0,10,0"/>
                
                <!-- Response Preview -->
                <Border Grid.Column="3"
                        Background="#1E1E28"
                        CornerRadius="4"
                        Width="300"
                        Height="60">
                    <TextBlock x:Name="ResponseText"
                              Text="Ready..."
                              Foreground="#00FF00"
                              FontSize="11"
                              FontFamily="Monospace"
                              TextWrapping="Wrap"
                              Margin="5"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>